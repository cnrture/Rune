<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.teknasyon.plugin</id>
    <name>TPDevTools</name>
    <vendor>Teknasyon</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="TeknasyonIntelliJPlugin" displayType="BALLOON" isLogByDefault="false"/>
        <toolWindow
                factoryClass="com.github.teknasyon.plugin.toolwindow.claude.ClaudeToolWindowFactory"
                id="Claude"
                anchor="right"
                icon="/icons/claudeIcon.svg"/>

        <editorNotificationProvider
                implementation="com.github.teknasyon.plugin.actions.SkillBestPracticesNotificationProvider"/>

        <!-- Settings Configurable -->
        <projectConfigurable
                parentId="tools"
                instance="com.github.teknasyon.plugin.service.PluginConfigurable"
                id="com.github.teknasyon.ai.settings"
                displayName="Teknasyon Plugin"/>
    </extensions>

    <actions>
        <action
                id="TeknasyonAndroidStudioPlugin.GenerateCommitMessage"
                class="com.github.teknasyon.plugin.actions.GenerateCommitMessageAction"
                text="Generate Commit Message with Claude"
                description="Generate a conventional commit message from staged changes using Claude AI"
                icon="AllIcons.Actions.Lightning">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
        </action>
        <action
                id="TeknasyonAndroidStudioPlugin.CreateReviewPR"
                class="com.github.teknasyon.plugin.actions.CreateReviewPRAction"
                text="Create Review PR"
                description="Create review branch from base, push current branch, and open a PR"
                icon="AllIcons.Vcs.Branch">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="after"
                          relative-to-action="TeknasyonAndroidStudioPlugin.GenerateCommitMessage"/>
        </action>
        <action
                id="TeknasyonAndroidStudioPlugin.FixPRComments"
                class="com.github.teknasyon.plugin.actions.FixPRCommentsAction"
                text="Fix PR Comments"
                description="Fetch unresolved PR comments and fix them with Claude"
                icon="AllIcons.Actions.PreviewDetails">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="after"
                          relative-to-action="TeknasyonAndroidStudioPlugin.CreateReviewPR"/>
        </action>
        <action
                id="TeknasyonAndroidStudioPlugin.AskClaude"
                class="com.github.teknasyon.plugin.actions.AskClaudeAction"
                text="Ask Claude"
                description="Send selected code to Claude terminal"
                icon="/icons/claudeIcon.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ConsoleEditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>