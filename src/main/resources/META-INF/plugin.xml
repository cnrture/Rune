<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.teknasyon.plugin</id>
    <name>TPDevTools</name>
    <vendor>Teknasyon</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="TP Notification Group"
                           displayType="BALLOON"/>
        <postStartupActivity
                implementation="com.github.teknasyon.plugin.startup.NewsletterStartupActivity"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                factoryClass="com.github.teknasyon.plugin.TPToolWindowFactory"
                id="TPDevTools"
                anchor="right"
                icon="/icons/pluginIcon.svg"/>
    </extensions>

    <actions>
        <action id="TPDevTools.NewFeature"
                class="com.github.teknasyon.plugin.toolwindow.manager.featuregenerator.action.FeatureGeneratorAction"
                text="Add Feature"
                description="Create a new feature"
                icon="/icons/pluginIcon.svg">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewDir"/>
        </action>
        <action id="TPDevTools.NewModule"
                class="com.github.teknasyon.plugin.toolwindow.manager.modulegenerator.action.ModuleGeneratorAction"
                text="New Module with This Files"
                description="Create a new module with the selected files"
                icon="/icons/pluginIcon.svg">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewDir"/>
        </action>
    </actions>
</idea-plugin>