<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.teknasyon.plugin</id>
    <name>TPDevTools</name>
    <vendor>Teknasyon</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="TP Notification Group"
                           displayType="BALLOON"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="SkillDock" displayType="BALLOON" isLogByDefault="false"/>
        <toolWindow
                factoryClass="com.github.teknasyon.plugin.TPToolWindowFactory"
                id="TPDevTools"
                anchor="right"
                icon="/icons/pluginIcon.svg"/>
        <toolWindow
                factoryClass="com.github.teknasyon.plugin.toolwindow.claude.ClaudeToolWindowFactory"
                id="Claude"
                anchor="right"
                icon="/icons/claudeIcon.svg"/>

        <!-- Settings Configurable -->
        <projectConfigurable
                parentId="tools"
                instance="com.github.teknasyon.plugin.service.SkillDockConfigurable"
                id="com.github.teknasyon.ai.settings"
                displayName="SkillDock"/>
    </extensions>

    <actions>
        <action id="TPDevTools.NewFeature"
                class="com.github.teknasyon.plugin.toolwindow.manager.featuregenerator.action.FeatureGeneratorAction"
                text="Add Feature"
                description="Create a new feature"
                icon="/icons/pluginIcon.svg">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewDir"/>
        </action>
        <action id="TPDevTools.NewModule"
                class="com.github.teknasyon.plugin.toolwindow.manager.modulegenerator.action.ModuleGeneratorAction"
                text="New Module with This Files"
                description="Create a new module with the selected files"
                icon="/icons/pluginIcon.svg">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewDir"/>
        </action>
        <action
                id="SkillDock.GenerateCommitMessage"
                class="com.github.teknasyon.plugin.actions.GenerateCommitMessageAction"
                text="Generate Commit Message with Claude"
                description="Generate a conventional commit message from staged changes using Claude AI"
                icon="AllIcons.Actions.Lightning">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
        </action>
        <action
                id="SkillDock.CreateReviewPR"
                class="com.github.teknasyon.plugin.actions.CreateReviewPRAction"
                text="Create Review PR"
                description="Create review branch from base, push current branch, and open a PR"
                icon="AllIcons.Vcs.Branch">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="after"
                          relative-to-action="SkillDock.GenerateCommitMessage"/>
        </action>
        <action
                id="SkillDock.AskClaude"
                class="com.github.teknasyon.plugin.actions.AskClaudeAction"
                text="Ask Claude"
                description="Send selected code to Claude terminal"
                icon="/icons/claudeIcon.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>