<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.cnrture.rune</id>
    <name>Rune</name>
    <vendor>cnrture</vendor>

    <description><![CDATA[
    <h2>Rune — Claude CLI Integration for JetBrains IDEs</h2>
    <p>Seamlessly integrate <b>Claude CLI</b> into your JetBrains IDE with a powerful terminal-based workflow.</p>

    <h3>Features</h3>
    <ul>
        <li><b>Claude Terminal</b> — Embedded Claude CLI sessions with multi-tab support</li>
        <li><b>Commit Message Generation</b> — AI-powered conventional commit messages from staged diffs</li>
        <li><b>PR Creation &amp; Review</b> — Create review branches and PRs (GitHub &amp; Bitbucket)</li>
        <li><b>Fix PR Comments</b> — Auto-fix unresolved PR review comments with Claude</li>
        <li><b>Ask Claude</b> — Right-click any code selection to send it to Claude</li>
        <li><b>Skills &amp; Agents</b> — Browse and execute custom skills and agents</li>
        <li><b>Command Palette</b> — Quick access to all Claude commands</li>
        <li><b>Skill Best Practices</b> — Validate SKILL.md files against Claude platform guidelines</li>
    </ul>

    <h3>Requirements</h3>
    <ul>
        <li><a href="https://docs.anthropic.com/en/docs/claude-cli">Claude CLI</a> installed and authenticated</li>
    </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="RunePlugin" displayType="BALLOON" isLogByDefault="false"/>
        <toolWindow
                factoryClass="com.github.cnrture.rune.toolwindow.ClaudeToolWindowFactory"
                id="Claude"
                anchor="right"
                icon="/icons/pluginIcon.svg"/>

        <!-- Settings Configurable -->
        <projectConfigurable
                parentId="tools"
                instance="com.github.cnrture.rune.service.PluginConfigurable"
                id="com.github.cnrture.rune.settings"
                displayName="Rune"/>
    </extensions>

    <actions>
        <action
                id="Rune.GenerateCommitMessage"
                class="com.github.cnrture.rune.actions.GenerateCommitMessageAction"
                text="Generate Commit Message with Claude"
                description="Generate a conventional commit message from staged changes using Claude AI"
                icon="AllIcons.Actions.Lightning">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
        </action>
        <action
                id="Rune.CreateReviewPR"
                class="com.github.cnrture.rune.actions.CreateReviewPRAction"
                text="Create Review PR"
                description="Create review branch from base, push current branch, and open a PR"
                icon="AllIcons.Vcs.Branch">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="after"
                          relative-to-action="Rune.GenerateCommitMessage"/>
        </action>
        <action
                id="Rune.FixPRComments"
                class="com.github.cnrture.rune.actions.FixPRCommentsAction"
                text="Fix PR Comments"
                description="Fetch unresolved PR comments and fix them with Claude"
                icon="AllIcons.Actions.PreviewDetails">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="after"
                          relative-to-action="Rune.CreateReviewPR"/>
        </action>
        <action
                id="Rune.AskClaude"
                class="com.github.cnrture.rune.actions.AskClaudeAction"
                text="Ask Claude"
                description="Send selected code to Claude terminal"
                icon="/icons/pluginIcon.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ConsoleEditorPopupMenu" anchor="last"/>
        </action>
        <action
                id="Rune.CheckSkillBestPractices"
                class="com.github.cnrture.rune.actions.CheckSkillBestPracticesAction"
                text="Check Skill with Claude"
                description="Review SKILL.md against Claude platform best practices"
                icon="/icons/pluginIcon.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>